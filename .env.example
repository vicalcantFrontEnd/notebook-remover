# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ---- Google Drive ----
# The ID of your root course folder in Google Drive.
# Get it from the URL: drive.google.com/drive/folders/THIS_PART
DRIVE_ROOT_FOLDER_ID=1ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefg

# ---- Bunny CDN ----
# Found in: Bunny Dashboard → Account → API Keys
BUNNY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Edge Storage zone name (e.g. "mi-cursos")
BUNNY_STORAGE_ZONE=mi-cursos

# Storage API region hostname.
# Standard: storage.bunnycdn.com
# Other regions: de.storage.bunnycdn.com, la.storage.bunnycdn.com, etc.
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com

# Your Pull Zone hostname (e.g. "mi-cursos.b-cdn.net")
BUNNY_PULL_ZONE_HOSTNAME=mi-cursos.b-cdn.net

# ---- n8n ----
N8N_USER=admin
N8N_PASSWORD=change_this_password_NOW

# External URL where n8n is accessible (for webhooks)
N8N_WEBHOOK_URL=http://YOUR_VPS_IP:5678/

# ---- Pipeline options ----
# Removal method for videos: pixel | box | crop
PIPELINE_VIDEO_METHOD=pixel
# Removal method for images: pixel | box
PIPELINE_IMAGE_METHOD=pixel
# Removal method for PDFs: pixel | box
PIPELINE_PDF_METHOD=box
# Watermark detection sensitivity (5–80; lower = more aggressive)
PIPELINE_SENSITIVITY=30
# Trim this many seconds from the END of videos (for NotebookLM outro)
PIPELINE_TRIM_END_SECONDS=0
# Trim this many seconds from the END of audio files (m4a)
# Set to the length of the NotebookLM spoken watermark if any
AUDIO_TRIM_END_SECONDS=0

# ---- App ----
MAX_CONCURRENT_JOBS=1
TIMEZONE=America/Mexico_City
